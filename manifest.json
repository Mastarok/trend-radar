{
  "manifest_version": 3,
  "name": "热点雷达",
  "version": "0.1.3",
  "description": "聚合百度、微博、知乎、B站、贴吧、头条热榜的 Chrome 弹窗扩展。",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "declarativeNetRequest"],
  "host_permissions": [
    "https://top.baidu.com/*",
    "https://www.baidu.com/*",
    "https://api.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://www.bilibili.com/*",
    "https://tieba.baidu.com/*",
    "https://weibo.com/*",
    "https://s.weibo.com/*",
    "https://www.toutiao.com/*",
    "https://api.zhihu.com/*",
    "https://www.zhihu.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "打开热点雷达",
    "default_popup": "src/popup.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "request_headers",
        "enabled": true,
        "path": "rules/request-headers.json"
      }
    ]
  }
}
